# OpenAI API Key (required for LLM intent parsing)
OPENAI_API_KEY=sk-...

# WalletConnect Project ID (get from https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id

# Arc Testnet RPC (default public RPC)
NEXT_PUBLIC_ARC_TESTNET_RPC=https://rpc.testnet.arc.network

# Circle Config & Keys
CIRCLE_API_KEY=your_circle_api_key
CIRCLE_KIT_KEY=your_circle_kit_key
NEXT_PUBLIC_CIRCLE_CLIENT_KEY=your_circle_client_key
NEXT_PUBLIC_CIRCLE_CLIENT_URL=https://modular-sdk.circle.com/v1/rpc/w3s/buidl
CIRCLE_ENTITY_SECRET=your_circle_entity_secret
CIRCLE_APP_ID=your_circle_app_id
NEXT_PUBLIC_CIRCLE_APP_ID=your_circle_app_id
