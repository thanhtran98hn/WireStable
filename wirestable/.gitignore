# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing & Coverage
/coverage

# Next.js Build Outputs
/.next/
/out/
/build
/dist
.vercel
.turbo

# Environment & Secret Files (Never commit credentials)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local
.env*
*.pem
*.key
secrets.json
corporate_wallet.json
corporate_state.json

# Explicitly allow committing .env.example
!.env.example

# Logs & Debugging
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# System & IDEs
.DS_Store
Thumbs.db
.vscode/
.idea/

# TypeScript & Next.js auto-generated types
*.tsbuildinfo
next-env.d.ts

# Hardhat compilation paths
/artifacts/
/cache/

# Temporary files
emojis_found.txt
